rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic auth check placeholder, or change to true for testing if no auth is set up
    function isAuth() { return true; /* request.auth != null; */ }

    match /projects/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /cloudResources/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /reapEvents/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;  // immutable log
    }
    match /reapSummary/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    
    // Existing artifact rules (if any from previous features)
    match /artifacts/{document=**} {
      allow read, write: if true;
    }
  }
}
